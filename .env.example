# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="GPSA-UDS Website API"
ENVIRONMENT=development          # development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://vermithor:SecurePass!123@localhost:5432/gpsauddb
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# ── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-secret-key-min-32-chars-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Security ──────────────────────────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=10
PASSWORD_RESET_TOKEN_EXPIRE_HOURS=1
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24

# ── Object Storage (Cloudflare R2 / AWS S3) ───────────────────────────────────
STORAGE_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY_ID=your-r2-access-key-id
STORAGE_SECRET_ACCESS_KEY=your-r2-secret-access-key
STORAGE_BUCKET_NAME=gpsauds-assets
STORAGE_PUBLIC_URL=https://assets.yourdomain.com   # CDN public URL prefix

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM_ADDRESS=noreply@gpsa-uds.edu.gh
EMAIL_FROM_NAME="GPSA-UDS"

# ── First Admin Seed ──────────────────────────────────────────────────────────
FIRST_ADMIN_EMAIL=admin@gpsa-uds.edu.gh
FIRST_ADMIN_PASSWORD=change-me-immediately
